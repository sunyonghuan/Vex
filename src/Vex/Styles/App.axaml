<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="Inter, Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Background" Value="{DynamicResource VexShellBackgroundBrush}" />
    </Style>
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource VexEditorForegroundBrush}" />
    </Style>
    <Style Selector="Menu.title-menu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource VexMenuForegroundBrush}" />
    </Style>
    <Style Selector="Menu.title-menu MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource VexMenuForegroundBrush}" />
    </Style>
    <Style Selector="Menu.title-menu MenuItem:toplevel">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="2 0" />
    </Style>
    <Style Selector="Menu.title-menu MenuItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource VexMenuHoverBackgroundBrush}" />
    </Style>
    <Style Selector="Menu.title-menu MenuItem:checked">
        <Setter Property="Background" Value="{DynamicResource VexMenuCheckedBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource VexMenuCheckedForegroundBrush}" />
    </Style>
    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource VexPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource VexPanelBorderBrush}" />
    </Style>
    <Style Selector="ContextMenu MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource VexMenuForegroundBrush}" />
    </Style>
    <Style Selector="ContextMenu MenuItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource VexMenuHoverBackgroundBrush}" />
    </Style>
    <Style Selector="TabControl.sidebar-tabs TabItem">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource VexPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource VexPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0 0 1 0" />
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource VexMutedTextBrush}" />
    </Style>
    <Style Selector="TextBlock.side-heading">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource VexSideHeadingTextBrush}" />
    </Style>
    <Style Selector="ListBox.side-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="10 8" />
        <Setter Property="MinHeight" Value="34" />
    </Style>
    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="{DynamicResource VexSplitterBrush}" />
    </Style>
</Styles>
