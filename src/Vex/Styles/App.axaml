<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="Inter, Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Background" Value="#FFFDFDFD" />
    </Style>
    <Style Selector="Menu.title-menu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Menu.title-menu MenuItem:toplevel">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="7 0" />
    </Style>
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="#FFFFFFFF" />
        <Setter Property="BorderBrush" Value="#E4E7EC" />
        <Setter Property="BorderThickness" Value="0 0 1 0" />
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="#667085" />
    </Style>
    <Style Selector="TextBlock.side-heading">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#98A2B3" />
    </Style>
    <Style Selector="Button.window-button">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.window-button:pointerover">
        <Setter Property="Background" Value="#EEF2F6" />
    </Style>
    <Style Selector="Button.window-button.close:pointerover">
        <Setter Property="Background" Value="#E5484D" />
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ListBox.side-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="10 8" />
        <Setter Property="MinHeight" Value="34" />
    </Style>
    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="#F2F4F7" />
    </Style>
</Styles>
