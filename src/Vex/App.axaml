                    <SolidColorBrush x:Key="VexEditorCurrentLineBackgroundBrush" Color="#FFF5E8" />
                    <SolidColorBrush x:Key="VexEditorCurrentLineBorderBrush" Color="#E8D9C2" />
                    <SolidColorBrush x:Key="VexPreviewBackgroundBrush" Color="#FFFBF5" />
                    <SolidColorBrush x:Key="VexStatusBarBackgroundBrush" Color="#FFFBF5" />
                    <SolidColorBrush x:Key="VexStatusBarBorderBrush" Color="#E8D9C2" />
                    <SolidColorBrush x:Key="VexStatusBadgeBackgroundBrush" Color="#FFF5E8" />
                    <SolidColorBrush x:Key="VexStatusBadgeBorderBrush" Color="#E8D9C2" />
                    <SolidColorBrush x:Key="VexStatusBadgeLabelBrush" Color="#7A6752" />
                    <SolidColorBrush x:Key="VexStatusBadgeValueBrush" Color="#32261B" />
                    <SolidColorBrush x:Key="VexLinkBrush" Color="#C77B2A" />
                    <SolidColorBrush x:Key="VexOverlayScrimBrush" Color="#66000000" />
                    <SolidColorBrush x:Key="VexMenuForegroundBrush" Color="#32261B" />
                    <SolidColorBrush x:Key="VexMenuHoverBackgroundBrush" Color="#FFF0D9" />
                    <SolidColorBrush x:Key="VexMenuCheckedBackgroundBrush" Color="#FFF0D9" />
                    <SolidColorBrush x:Key="VexMenuCheckedForegroundBrush" Color="#A9631C" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.Dusk}">
                    <SolidColorBrush x:Key="VexShellBackgroundBrush" Color="#F5F7FB" />
                    <SolidColorBrush x:Key="VexPanelBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="VexPanelBorderBrush" Color="#DDD7EA" />
                    <SolidColorBrush x:Key="VexMutedTextBrush" Color="#72637F" />
                    <SolidColorBrush x:Key="VexSideHeadingTextBrush" Color="#8A7A98" />
                    <SolidColorBrush x:Key="VexSplitterBrush" Color="#F0E9FF" />
                    <SolidColorBrush x:Key="VexEditorBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="VexEditorForegroundBrush" Color="#2C2237" />
                    <SolidColorBrush x:Key="VexEditorCurrentLineBackgroundBrush" Color="#F8F3FF" />
                    <SolidColorBrush x:Key="VexEditorCurrentLineBorderBrush" Color="#DDD7EA" />
                    <SolidColorBrush x:Key="VexPreviewBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="VexStatusBarBackgroundBrush" Color="#FBFCFF" />
                    <SolidColorBrush x:Key="VexStatusBarBorderBrush" Color="#DDD7EA" />
                    <SolidColorBrush x:Key="VexStatusBadgeBackgroundBrush" Color="#F3F1FA" />
                    <SolidColorBrush x:Key="VexStatusBadgeBorderBrush" Color="#DDD7EA" />
                    <SolidColorBrush x:Key="VexStatusBadgeLabelBrush" Color="#72637F" />
                    <SolidColorBrush x:Key="VexStatusBadgeValueBrush" Color="#2C2237" />
                    <SolidColorBrush x:Key="VexLinkBrush" Color="#8A63D2" />
                    <SolidColorBrush x:Key="VexOverlayScrimBrush" Color="#66000000" />
                    <SolidColorBrush x:Key="VexMenuForegroundBrush" Color="#2C2237" />
                    <SolidColorBrush x:Key="VexMenuHoverBackgroundBrush" Color="#F0E9FF" />
                    <SolidColorBrush x:Key="VexMenuCheckedBackgroundBrush" Color="#F0E9FF" />
                    <SolidColorBrush x:Key="VexMenuCheckedForegroundBrush" Color="#744CBC" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.NightSky}">
                    <SolidColorBrush x:Key="VexShellBackgroundBrush" Color="#0D1320" />
                    <SolidColorBrush x:Key="VexPanelBackgroundBrush" Color="#172033" />
                    <SolidColorBrush x:Key="VexPanelBorderBrush" Color="#2D3A52" />
                    <SolidColorBrush x:Key="VexMutedTextBrush" Color="#AAB6C8" />
                    <SolidColorBrush x:Key="VexSideHeadingTextBrush" Color="#7F8CA3" />
                    <SolidColorBrush x:Key="VexSplitterBrush" Color="#1E2A3F" />
                    <SolidColorBrush x:Key="VexEditorBackgroundBrush" Color="#0D1320" />
                    <SolidColorBrush x:Key="VexEditorForegroundBrush" Color="#EBF2FF" />
                    <SolidColorBrush x:Key="VexEditorCurrentLineBackgroundBrush" Color="#172033" />
                    <SolidColorBrush x:Key="VexEditorCurrentLineBorderBrush" Color="#2D3A52" />
                    <SolidColorBrush x:Key="VexPreviewBackgroundBrush" Color="#0D1320" />
                    <SolidColorBrush x:Key="VexStatusBarBackgroundBrush" Color="#111827" />
                    <SolidColorBrush x:Key="VexStatusBarBorderBrush" Color="#2D3A52" />
                    <SolidColorBrush x:Key="VexStatusBadgeBackgroundBrush" Color="#1E2A3F" />
                    <SolidColorBrush x:Key="VexStatusBadgeBorderBrush" Color="#2D3A52" />
                    <SolidColorBrush x:Key="VexStatusBadgeLabelBrush" Color="#AAB6C8" />
                    <SolidColorBrush x:Key="VexStatusBadgeValueBrush" Color="#EBF2FF" />
                    <SolidColorBrush x:Key="VexLinkBrush" Color="#7AA2FF" />
                    <SolidColorBrush x:Key="VexOverlayScrimBrush" Color="#99000000" />
                    <SolidColorBrush x:Key="VexMenuForegroundBrush" Color="#EBF2FF" />
                    <SolidColorBrush x:Key="VexMenuHoverBackgroundBrush" Color="#1E2A3F" />
                    <SolidColorBrush x:Key="VexMenuCheckedBackgroundBrush" Color="#1E335A" />
                    <SolidColorBrush x:Key="VexMenuCheckedForegroundBrush" Color="#9BB9FF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <FontFamily x:Key="ContentControlThemeFontFamily">Inter, Microsoft YaHei UI, Segoe UI</FontFamily>
            <FontFamily x:Key="ControlContentThemeFontFamily">Inter, Microsoft YaHei UI, Segoe UI</FontFamily>
            <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
            <x:Double x:Key="MenuFlyoutMaxHeight">Infinity</x:Double>
        </ResourceDictionary>
    </prism:PrismApplication.Resources>

    <prism:PrismApplication.Styles>
        <FluentTheme />
        <semi:SemiTheme Locale="zh-CN" />
        <semi:UrsaSemiTheme Locale="zh-CN" />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <codewf:CodeWFTheme />
        <markdownThemes:MarkdownThemes TypographyTheme="Simple" />
        <vexThemes:VexControlsTheme />
        <StyleInclude Source="Styles/App.axaml" />
    </prism:PrismApplication.Styles>
</prism:PrismApplication>
