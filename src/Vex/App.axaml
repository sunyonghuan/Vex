                    <SolidColorBrush x:Key="VexStatusBarBorderBrush" Color="#CDE9EF" />
                    <SolidColorBrush x:Key="VexStatusBadgeBackgroundBrush" Color="#EFF8FA" />
                    <SolidColorBrush x:Key="VexStatusBadgeBorderBrush" Color="#CDE9EF" />
                    <SolidColorBrush x:Key="VexStatusBadgeLabelBrush" Color="#5C7880" />
                    <SolidColorBrush x:Key="VexStatusBadgeValueBrush" Color="#16323A" />
                    <SolidColorBrush x:Key="VexLinkBrush" Color="#0EA5B7" />
                    <SolidColorBrush x:Key="VexOverlayScrimBrush" Color="#66000000" />
                    <SolidColorBrush x:Key="VexMenuForegroundBrush" Color="#16323A" />
                    <SolidColorBrush x:Key="VexMenuHoverBackgroundBrush" Color="#DFF7FA" />
                    <SolidColorBrush x:Key="VexMenuCheckedBackgroundBrush" Color="#DFF7FA" />
                    <SolidColorBrush x:Key="VexMenuCheckedForegroundBrush" Color="#07879A" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.Desert}">
                    <SolidColorBrush x:Key="VexShellBackgroundBrush" Color="#FCF7F0" />
                    <SolidColorBrush x:Key="VexPanelBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="VexPanelBorderBrush" Color="#E8D9C2" />
