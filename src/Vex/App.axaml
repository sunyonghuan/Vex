                </ResourceDictionary>
                <ResourceDictionary x:Key="{x:Static semi:SemiTheme.Aquatic}">
                    <SolidColorBrush x:Key="VexShellBackgroundBrush" Color="#F0FAFD" />
                    <SolidColorBrush x:Key="VexPanelBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="VexPanelBorderBrush" Color="#CDE9EF" />
                    <SolidColorBrush x:Key="VexMutedTextBrush" Color="#5C7880" />
                    <SolidColorBrush x:Key="VexSideHeadingTextBrush" Color="#7A99A1" />
                    <SolidColorBrush x:Key="VexSplitterBrush" Color="#DFF7FA" />
                    <SolidColorBrush x:Key="VexEditorBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="VexEditorForegroundBrush" Color="#16323A" />
