<UserControl
    x:Class="Vex.Modules.Shell.Views.ShellRenameFileOverlayView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:Vex.Core.Behaviors"
    xmlns:i18n="https://codewf.com"
    xmlns:l="clr-namespace:Vex"
    xmlns:vm="using:Vex.Modules.Shell.ViewModels"
    x:DataType="vm:MainWindowViewModel">
    <Border
        Background="{DynamicResource VexOverlayScrimBrush}"
        IsVisible="{Binding Dialogs.IsRenameFilePanelVisible}"
        behaviors:FocusOnVisible.TargetName="RenameFileNameTextBox"
        behaviors:FocusOnVisible.SelectAll="True">
        <Border
            Width="430"
            Padding="22"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource VexPanelBackgroundBrush}"
            BorderBrush="{DynamicResource VexPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                <TextBlock
                    FontSize="17"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource VexEditorForegroundBrush}"
                    Text="{i18n:I18n {x:Static l:VexL.RenameFileTitle}}"
                    TextWrapping="Wrap" />
                <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="6">
                    <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:VexL.RenameFileNameLabel}}" />
                    <TextBox
                        x:Name="RenameFileNameTextBox"
                        Grid.Row="1"
                        PlaceholderText="{i18n:I18n {x:Static l:VexL.RenameFileNameLabel}}"
                        Text="{Binding Dialogs.RenameFileName, Mode=TwoWay}" />
                </Grid>
                <Border
                    Grid.Row="2"
                    Padding="10 8"
                    Background="{DynamicResource VexStatusBadgeBackgroundBrush}"
                    BorderBrush="{DynamicResource VexStatusBadgeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
                        <TextBlock
                            Classes="muted"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Text="{i18n:I18n {x:Static l:VexL.RenameFilePathLabel}}" />
                        <SelectableTextBlock
                            Grid.Row="1"
                            Classes="muted"
                            FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                            FontSize="12"
                            Text="{Binding Dialogs.RenameFilePath}"
                            TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <StackPanel
                    Grid.Row="3"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Command="{Binding Dialogs.CancelRenameFile}"
                        Content="{i18n:I18n {x:Static l:VexL.Cancel}}"
                        MinWidth="86" />
                    <Button
                        Command="{Binding ConfirmRenameFileAsync}"
                        Content="{i18n:I18n {x:Static l:VexL.Rename}}"
                        MinWidth="86" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
