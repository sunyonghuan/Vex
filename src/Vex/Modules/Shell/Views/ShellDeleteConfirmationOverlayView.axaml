<UserControl
    x:Class="Vex.Modules.Shell.Views.ShellDeleteConfirmationOverlayView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i18n="https://codewf.com"
    xmlns:l="clr-namespace:Vex"
    xmlns:vm="using:Vex.Modules.Shell.ViewModels"
    x:DataType="vm:MainWindowViewModel">
    <Border Background="#66000000" IsVisible="{Binding Dialogs.IsDeleteConfirmVisible}">
        <Border
            Width="420"
            Padding="22"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#FFFFFFFF"
            BorderBrush="#D0D5DD"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                <TextBlock
                    FontSize="17"
                    FontWeight="SemiBold"
                    Text="{Binding Dialogs.DeleteConfirmText}"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Classes="muted"
                    Text="{i18n:I18n {x:Static l:VexL.DeletePermanentWarning}}"
                    TextWrapping="Wrap" />
                <Border
                    Grid.Row="2"
                    Padding="10 8"
                    Background="#FFF8FAFC"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    CornerRadius="6">
                    <TextBlock
                        Classes="muted"
                        FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                        FontSize="12"
                        Text="{Binding Dialogs.DeleteConfirmPath}"
                        TextTrimming="CharacterEllipsis" />
                </Border>
                <StackPanel
                    Grid.Row="3"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Command="{Binding Dialogs.CancelDelete}"
                        Content="{i18n:I18n {x:Static l:VexL.Cancel}}"
                        MinWidth="86" />
                    <Button
                        Command="{Binding ConfirmDeleteAsync}"
                        Content="{i18n:I18n {x:Static l:VexL.Delete}}"
                        MinWidth="86" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
