<UserControl
    x:Class="Vex.Modules.Shell.Views.ShellUnsavedConfirmationOverlayView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i18n="https://codewf.com"
    xmlns:l="clr-namespace:Vex"
    xmlns:vm="using:Vex.Modules.Shell.ViewModels"
    x:DataType="vm:MainWindowViewModel">
    <Border Background="#66000000" IsVisible="{Binding Dialogs.IsUnsavedConfirmVisible}">
        <Border
            Width="440"
            Padding="22"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource VexPanelBackgroundBrush}"
            BorderBrush="{DynamicResource VexPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                <TextBlock
                    FontSize="17"
                    FontWeight="SemiBold"
                    Text="{Binding Dialogs.UnsavedConfirmTitle}"
                    TextWrapping="Wrap" />
                <TextBlock
                    Grid.Row="1"
                    Classes="muted"
                    Text="{Binding Dialogs.UnsavedConfirmMessage}"
                    TextWrapping="Wrap" />
                <Border
                    Grid.Row="2"
                    Padding="10 8"
                    Background="{DynamicResource VexStatusBadgeBackgroundBrush}"
                    BorderBrush="{DynamicResource VexStatusBadgeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <TextBlock
                        Classes="muted"
                        FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                        FontSize="12"
                        Text="{Binding Dialogs.UnsavedConfirmPath}"
                        TextTrimming="CharacterEllipsis" />
                </Border>
                <StackPanel
                    Grid.Row="3"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Command="{Binding Dialogs.CancelPendingAction}"
                        Content="{i18n:I18n {x:Static l:VexL.Cancel}}"
                        MinWidth="84" />
                    <Button
                        Command="{Binding DiscardPendingActionAsync}"
                        Content="{i18n:I18n {x:Static l:VexL.DoNotSave}}"
                        MinWidth="104" />
                    <Button
                        Command="{Binding SavePendingActionAsync}"
                        Content="{i18n:I18n {x:Static l:VexL.Save}}"
                        MinWidth="84" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
