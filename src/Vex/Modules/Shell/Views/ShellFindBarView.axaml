<UserControl
    x:Class="Vex.Modules.Shell.Views.ShellFindBarView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Vex.Modules.Shell.ViewModels"
    x:DataType="vm:ShellFindBarViewModel"
    IsVisible="{Binding IsVisible}">

    <Border
        Background="#FFFFFFFF"
        BorderBrush="#E4E7EC"
        BorderThickness="0 0 0 1"
        Padding="10 8">
        <Grid ColumnDefinitions="Auto,220,Auto,220,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
            <TextBlock
                Classes="muted"
                Text="Find"
                VerticalAlignment="Center" />
            <TextBox
                x:Name="FindTextBox"
                Grid.Column="1"
                MinHeight="30"
                PlaceholderText="Text"
                Text="{Binding SearchText, Mode=TwoWay}" />
            <TextBlock
                Grid.Column="2"
                Classes="muted"
                IsVisible="{Binding IsReplaceVisible}"
                Text="Replace"
                VerticalAlignment="Center" />
            <TextBox
                Grid.Column="3"
                IsVisible="{Binding IsReplaceVisible}"
                MinHeight="30"
                PlaceholderText="Text"
                Text="{Binding ReplacementText, Mode=TwoWay}" />
            <Button
                Grid.Column="4"
                Command="{Binding FindNext}"
                Content="Next"
                MinWidth="72" />
            <Button
                Grid.Column="5"
                Command="{Binding ReplaceNext}"
                Content="Replace"
                IsVisible="{Binding IsReplaceVisible}"
                MinWidth="82" />
            <Button
                Grid.Column="6"
                Command="{Binding ReplaceAll}"
                Content="All"
                IsVisible="{Binding IsReplaceVisible}"
                MinWidth="64" />
            <Button
                Grid.Column="7"
                Command="{Binding CloseFindPanel}"
                Content="X"
                MinWidth="42" />
            <TextBlock
                Grid.Column="8"
                Classes="muted"
                MinWidth="48"
                Text="{Binding SearchResultText}"
                TextAlignment="Right"
                VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
