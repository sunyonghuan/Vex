<Window
    x:Class="Vex.Modules.Shell.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Vex.Core.Messaging"
    xmlns:md="https://codewf.com"
    xmlns:models="using:Vex.Core.Models"
    xmlns:workspace="using:Vex.Modules.Workspace.Views"
    xmlns:vm="using:Vex.Modules.Shell.ViewModels"
    x:DataType="vm:MainWindowViewModel"
    Title="{Binding WindowTitle}"
    Width="1280"
    Height="820"
    MinWidth="980"
    MinHeight="640"
    Icon="/Assets/logo.ico"
    WindowDecorations="None"
    WindowStartupLocation="CenterScreen">

    <Window.DataTemplates>
        <DataTemplate DataType="models:DocumentFile">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="3">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Classes="side-heading" Text="{Binding FolderName}" />
                    <TextBlock
                        Grid.Column="1"
                        Classes="muted"
                        FontSize="11"
                        Text="{Binding ModifiedText}" />
                </Grid>
                <TextBlock
                    Grid.Row="1"
                    FontWeight="SemiBold"
                    Text="{Binding Name}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="2"
                    Classes="muted"
                    MaxHeight="38"
                    Text="{Binding Preview}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="models:OutlineItem">
            <TextBlock
                Margin="{Binding IndentMargin}"
                Text="{Binding Title}"
                TextTrimming="CharacterEllipsis" />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="34,*,Auto" Background="#FFFDFDFD">
        <Border
            Grid.Row="0"
            Background="#FFF7F8FA"
            BorderBrush="#E4E7EC"
            BorderThickness="0 0 0 1"
            PointerPressed="TitleBarPointerPressed">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <StackPanel
                    Margin="10 0 10 0"
                    Orientation="Horizontal"
                    Spacing="7"
                    VerticalAlignment="Center">
                    <Image Width="16" Height="16" Source="/Assets/logo.png" />
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Vex"
                        VerticalAlignment="Center" />
                </StackPanel>

                <Menu
                    Grid.Column="1"
                    Classes="title-menu"
                    VerticalAlignment="Center">
                    <MenuItem Header="文件(F)">
                        <MenuItem Header="新建" Command="{Binding NewDocumentCommand}" />
                        <MenuItem Header="新建窗口" Command="{Binding NewWindowCommand}" />
                        <Separator />
                        <MenuItem Header="打开..." Command="{Binding OpenCommand}" />
                        <MenuItem Header="打开文件夹..." Command="{Binding OpenFolderCommand}" />
                        <MenuItem Header="快速打开..." Command="{Binding QuickOpenCommand}" />
                        <MenuItem Header="打开最近文件" IsEnabled="False" />
                        <MenuItem Header="选择编码重新打开">
                            <MenuItem Header="UTF-8" Command="{Binding ReopenWithEncodingCommand}" CommandParameter="utf-8" />
                            <MenuItem Header="UTF-8 BOM" Command="{Binding ReopenWithEncodingCommand}" CommandParameter="utf-8-bom" />
                            <MenuItem Header="GB18030" Command="{Binding ReopenWithEncodingCommand}" CommandParameter="GB18030" />
                            <MenuItem Header="Big5" Command="{Binding ReopenWithEncodingCommand}" CommandParameter="Big5" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="保存" Command="{Binding SaveCommand}" />
                        <MenuItem Header="另存为..." Command="{Binding SaveAsCommand}" />
                        <MenuItem Header="保存全部打开的文件..." Command="{Binding SaveAllCommand}" />
                        <Separator />
                        <MenuItem Header="属性..." Command="{Binding ShowPropertiesCommand}" />
                        <MenuItem Header="打开文件位置..." Command="{Binding OpenFileLocationCommand}" />
                        <MenuItem Header="删除..." Command="{Binding DeleteCommand}" />
                        <Separator />
                        <MenuItem Header="导出">
                            <MenuItem Header="HTML" Command="{Binding ExportCommand}" CommandParameter="HTML" />
                            <MenuItem Header="PDF" Command="{Binding ExportCommand}" CommandParameter="PDF" />
                            <MenuItem Header="PNG" Command="{Binding ExportCommand}" CommandParameter="PNG" />
                        </MenuItem>
                        <MenuItem Header="打印..." Command="{Binding PrintCommand}" />
                        <Separator />
                        <MenuItem Header="关闭" Command="{Binding CloseDocumentCommand}" />
                    </MenuItem>

                    <MenuItem Header="编辑(E)">
                        <MenuItem Header="撤销" Command="{Binding UndoCommand}" />
                        <MenuItem Header="重做" Command="{Binding RedoCommand}" />
                        <Separator />
                        <MenuItem Header="剪切" Command="{Binding CutCommand}" />
                        <MenuItem Header="复制" Command="{Binding CopyCommand}" />
                        <MenuItem Header="粘贴" Command="{Binding PasteCommand}" />
                        <MenuItem Header="全选" Command="{Binding SelectAllCommand}" />
                        <Separator />
                        <MenuItem Header="查找..." Command="{Binding HelpCommand}" CommandParameter="search" />
                        <MenuItem Header="替换..." Command="{Binding HelpCommand}" CommandParameter="replace" />
                    </MenuItem>

                    <MenuItem Header="段落(P)">
                        <MenuItem Header="段落" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Paragraph}" />
                        <MenuItem Header="标题 1" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Heading1}" />
                        <MenuItem Header="标题 2" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Heading2}" />
                        <MenuItem Header="标题 3" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Heading3}" />
                        <MenuItem Header="标题 4" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Heading4}" />
                        <MenuItem Header="标题 5" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Heading5}" />
                        <MenuItem Header="标题 6" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Heading6}" />
                        <Separator />
                        <MenuItem Header="表格" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Table}" />
                        <MenuItem Header="代码块" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.CodeFence}" />
                        <MenuItem Header="公式块" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.MathBlock}" />
                        <MenuItem Header="引用" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Quote}" />
                        <MenuItem Header="有序列表" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.OrderedList}" />
                        <MenuItem Header="无序列表" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.UnorderedList}" />
                        <MenuItem Header="任务列表" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.TaskList}" />
                        <MenuItem Header="水平分割线" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.HorizontalRule}" />
                    </MenuItem>

                    <MenuItem Header="格式(O)">
                        <MenuItem Header="加粗" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Bold}" />
                        <MenuItem Header="斜体" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Italic}" />
                        <MenuItem Header="代码" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.InlineCode}" />
                        <Separator />
                        <MenuItem Header="链接" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Link}" />
                        <MenuItem Header="图像" Command="{Binding InsertActionCommand}" CommandParameter="{x:Static core:EditorActionKind.Image}" />
                        <MenuItem Header="清除样式" Command="{Binding HelpCommand}" CommandParameter="clear-format" />
                    </MenuItem>

                    <MenuItem Header="视图(V)">
                        <MenuItem Header="显示 / 隐藏侧边栏" Command="{Binding ToggleSidebarCommand}" />
                        <MenuItem Header="大纲" Command="{Binding ShowOutlineCommand}" />
                        <MenuItem Header="文档列表" Command="{Binding ShowFilesCommand}" />
                        <MenuItem Header="搜索" Command="{Binding HelpCommand}" CommandParameter="search" />
                        <Separator />
                        <MenuItem Header="源代码模式" Command="{Binding ToggleSourceModeCommand}" />
                        <MenuItem Header="显示状态栏" Command="{Binding ToggleStatusBarCommand}" />
                        <MenuItem Header="字数统计窗口" Command="{Binding WordCountCommand}" />
                        <Separator />
                        <MenuItem Header="切换全屏" Command="{Binding ToggleFullScreenCommand}" />
                        <MenuItem Header="保持窗口在最前端" Command="{Binding ToggleAlwaysOnTopCommand}" />
                        <Separator />
                        <MenuItem Header="实际大小" Command="{Binding ActualSizeCommand}" />
                        <MenuItem Header="放大" Command="{Binding ZoomInCommand}" />
                        <MenuItem Header="缩小" Command="{Binding ZoomOutCommand}" />
                    </MenuItem>

                    <MenuItem Header="主题(T)">
                        <MenuItem Header="主题色">
                            <MenuItem Header="Light" Command="{Binding SelectThemeByKeyCommand}" CommandParameter="light" />
                            <MenuItem Header="Dark" Command="{Binding SelectThemeByKeyCommand}" CommandParameter="dark" />
                            <MenuItem Header="System" Command="{Binding SelectThemeByKeyCommand}" CommandParameter="system" />
                        </MenuItem>
                        <MenuItem Header="排版">
                            <MenuItem Header="简洁" Command="{Binding SelectTypographyByKeyCommand}" CommandParameter="Simple" />
                            <MenuItem Header="Basic" Command="{Binding SelectTypographyByKeyCommand}" CommandParameter="Basic" />
                            <MenuItem Header="橙心" Command="{Binding SelectTypographyByKeyCommand}" CommandParameter="OrangeHeart" />
                            <MenuItem Header="墨黑" Command="{Binding SelectTypographyByKeyCommand}" CommandParameter="InkBlack" />
                            <MenuItem Header="科技蓝" Command="{Binding SelectTypographyByKeyCommand}" CommandParameter="TechnologyBlue" />
                            <Separator />
                            <MenuItem Header="紧凑布局" Command="{Binding ToggleCompactLayoutCommand}" />
                        </MenuItem>
                    </MenuItem>

                    <MenuItem Header="国际化(L)">
                        <MenuItem Header="简体中文" Command="{Binding SelectLanguageByCultureCommand}" CommandParameter="zh-CN" />
                        <MenuItem Header="繁體中文" Command="{Binding SelectLanguageByCultureCommand}" CommandParameter="zh-Hant" />
                        <MenuItem Header="English" Command="{Binding SelectLanguageByCultureCommand}" CommandParameter="en-US" />
                        <MenuItem Header="日本語" Command="{Binding SelectLanguageByCultureCommand}" CommandParameter="ja-JP" />
                    </MenuItem>

                    <MenuItem Header="帮助(H)">
                        <MenuItem Header="更新日志" Command="{Binding HelpCommand}" CommandParameter="changelog" />
                        <MenuItem Header="快速开始（引导）" Command="{Binding HelpCommand}" CommandParameter="quick-start" />
                        <MenuItem Header="鸣谢" Command="{Binding HelpCommand}" CommandParameter="thanks" />
                        <Separator />
                        <MenuItem Header="官方网站" Command="{Binding HelpCommand}" CommandParameter="website" />
                        <MenuItem Header="反馈" Command="{Binding HelpCommand}" CommandParameter="feedback" />
                        <MenuItem Header="关于" Command="{Binding HelpCommand}" CommandParameter="about" />
                    </MenuItem>
                </Menu>

                <TextBlock
                    Grid.Column="2"
                    Classes="muted"
                    FontSize="12"
                    HorizontalAlignment="Center"
                    Text="{Binding CurrentDocumentTitle}"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center" />

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Classes="window-button" Click="MinimizeClicked" Content="_" />
                    <Button Classes="window-button" Click="MaximizeClicked" Content="[]" />
                    <Button Classes="window-button close" Click="CloseClicked" Content="X" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarColumnWidth}" MinWidth="0" />
                <ColumnDefinition Width="{Binding SidebarSplitterWidth}" />
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition Width="{Binding PreviewSplitterWidth}" />
                <ColumnDefinition Width="{Binding PreviewColumnWidth}" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Classes="panel" IsVisible="{Binding IsSidebarVisible}">
                <TabControl SelectedIndex="{Binding SelectedSideTabIndex, Mode=TwoWay}">
                    <TabItem Header="文件">
                        <ListBox
                            Classes="side-list"
                            ItemsSource="{Binding DocumentFiles}"
                            SelectedItem="{Binding SelectedDocumentFile, Mode=TwoWay}" />
                    </TabItem>
                    <TabItem Header="大纲">
                        <ListBox
                            Classes="side-list"
                            ItemsSource="{Binding OutlineItems}" />
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsSidebarVisible}"
                ResizeDirection="Columns" />

            <workspace:MarkdownEditorView Grid.Column="2" />

            <GridSplitter
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsPreviewVisible}"
                ResizeDirection="Columns" />

            <Border
                Grid.Column="4"
                Background="White"
                IsVisible="{Binding IsPreviewVisible}"
                Padding="34 28 34 0">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <md:MarkdownViewer
                        Markdown="{Binding Markdown}"
                        TypographySize="{Binding CurrentTypographySize}"
                        TypographyTheme="{Binding CurrentTypographyTheme}" />
                </ScrollViewer>
            </Border>
        </Grid>

        <Border
            Grid.Row="2"
            Background="#FFF7F8FA"
            BorderBrush="#E4E7EC"
            BorderThickness="0 1 0 0"
            IsVisible="{Binding IsStatusBarVisible}"
            Padding="10 4">
            <Grid ColumnDefinitions="*,Auto" MinHeight="28">
                <TextBlock
                    Classes="muted"
                    Text="{Binding StatusText}"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center" />
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <TextBlock Classes="muted" Text="{Binding ZoomText}" VerticalAlignment="Center" />
                    <md:VexStatusBadge Label="Line" Value="{Binding CaretLine}" />
                    <md:VexStatusBadge Label="Col" Value="{Binding CaretColumn}" />
                    <md:VexStatusBadge Label="Words" Value="{Binding Statistics.Words}" />
                    <md:VexStatusBadge Label="Chars" Value="{Binding Statistics.Characters}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
