<Window
    x:Class="Vex.Modules.Shell.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i18n="https://codewf.com"
    xmlns:l="clr-namespace:Vex"
    xmlns:md="https://codewf.com"
    xmlns:models="using:Vex.Core.Models"
    xmlns:shell="using:Vex.Modules.Shell.Views"
    xmlns:workspace="using:Vex.Modules.Workspace.Views"
    xmlns:vm="using:Vex.Modules.Shell.ViewModels"
    x:DataType="vm:MainWindowViewModel"
    Title="{Binding DocumentInfo.WindowTitle}"
    Width="1280"
    Height="820"
    MinWidth="980"
    MinHeight="640"
    Icon="/Assets/logo.ico"
    KeyDown="WindowKeyDown"
    WindowDecorations="None"
    WindowStartupLocation="CenterScreen">

    <Window.DataTemplates>
        <DataTemplate DataType="models:DocumentFile">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="3">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Classes="side-heading" Text="{Binding FolderName}" />
                    <TextBlock
                        Grid.Column="1"
                        Classes="muted"
                        FontSize="11"
                        Text="{Binding ModifiedText}" />
                </Grid>
                <TextBlock
                    Grid.Row="1"
                    FontWeight="SemiBold"
                    Text="{Binding Name}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="2"
                    Classes="muted"
                    MaxHeight="38"
                    Text="{Binding Preview}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="models:OutlineItem">
            <TextBlock
                Margin="{Binding IndentMargin}"
                Text="{Binding Title}"
                TextTrimming="CharacterEllipsis" />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="34,Auto,*,Auto" Background="#FFFDFDFD">
        <Border
            Grid.Row="0"
            Background="#FFF7F8FA"
            BorderBrush="#E4E7EC"
            BorderThickness="0 0 0 1"
            PointerPressed="TitleBarPointerPressed">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <StackPanel
                    Margin="10 0 10 0"
                    Orientation="Horizontal"
                    Spacing="7"
                    VerticalAlignment="Center">
                    <Image Width="16" Height="16" Source="/Assets/logo.png" />
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Vex"
                        VerticalAlignment="Center" />
                </StackPanel>

                <shell:ShellTitleMenuView Grid.Column="1" />

                <TextBlock
                    Grid.Column="2"
                    Classes="muted"
                    FontSize="12"
                    HorizontalAlignment="Center"
                    Text="{Binding DocumentInfo.CurrentDocumentTitle}"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center" />

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Classes="window-button" Click="MinimizeClicked" Content="_" />
                    <Button Classes="window-button" Click="MaximizeClicked" Content="[]" />
                    <Button Classes="window-button close" Click="CloseClicked" Content="X" />
                </StackPanel>
            </Grid>
        </Border>

        <shell:ShellFindBarView Grid.Row="1" DataContext="{Binding FindBar}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding Layout.SidebarColumnWidth}" MinWidth="0" />
                <ColumnDefinition Width="{Binding Layout.SidebarSplitterWidth}" />
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition Width="{Binding Layout.PreviewSplitterWidth}" />
                <ColumnDefinition Width="{Binding Layout.PreviewColumnWidth}" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Classes="panel" IsVisible="{Binding Layout.IsSidebarVisible}">
                <TabControl SelectedIndex="{Binding Navigation.SelectedSideTabIndex, Mode=TwoWay}">
                    <TabItem Header="{i18n:I18n {x:Static l:VexL.SidebarFiles}}">
                        <Grid>
                            <ListBox
                                Classes="side-list"
                                IsVisible="{Binding Navigation.HasDocumentFiles}"
                                ItemsSource="{Binding Navigation.DocumentFiles}"
                                SelectedItem="{Binding Navigation.SelectedDocumentFile, Mode=TwoWay}" />
                            <Border
                                IsVisible="{Binding Navigation.IsDocumentFilesEmpty}"
                                Padding="18"
                                VerticalAlignment="Top">
                                <TextBlock
                                    Classes="muted"
                                    Text="{i18n:I18n {x:Static l:VexL.EmptyNoFiles}}"
                                    TextAlignment="Center" />
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{i18n:I18n {x:Static l:VexL.SidebarOutline}}">
                        <Grid>
                            <ListBox
                                Classes="side-list"
                                IsVisible="{Binding Navigation.HasOutlineItems}"
                                ItemsSource="{Binding Navigation.OutlineItems}"
                                SelectedItem="{Binding Navigation.SelectedOutlineItem, Mode=TwoWay}" />
                            <Border
                                IsVisible="{Binding Navigation.IsOutlineEmpty}"
                                Padding="18"
                                VerticalAlignment="Top">
                                <TextBlock
                                    Classes="muted"
                                    Text="{i18n:I18n {x:Static l:VexL.EmptyNoHeadings}}"
                                    TextAlignment="Center" />
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding Layout.IsSidebarVisible}"
                ResizeDirection="Columns" />

            <workspace:MarkdownEditorView Grid.Column="2" />

            <GridSplitter
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding Layout.IsPreviewVisible}"
                ResizeDirection="Columns" />

            <Border
                Grid.Column="4"
                Background="White"
                IsVisible="{Binding Layout.IsPreviewVisible}"
                Padding="34 28 34 0">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <md:MarkdownViewer
                        Markdown="{Binding Markdown}"
                        TypographySize="{Binding Appearance.CurrentTypographySize}"
                        TypographyTheme="{Binding Appearance.CurrentTypographyTheme}" />
                </ScrollViewer>
            </Border>

            <shell:ShellOverlaysView Grid.ColumnSpan="5" />
        </Grid>

        <Border
            Grid.Row="3"
            Background="#FFF7F8FA"
            BorderBrush="#E4E7EC"
            BorderThickness="0 1 0 0"
            IsVisible="{Binding Layout.IsStatusBarVisible}"
            Padding="10 4">
            <Grid ColumnDefinitions="*,Auto" MinHeight="28">
                <TextBlock
                    Classes="muted"
                    Text="{Binding Status.StatusText}"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center" />
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <md:VexStatusBadge Label="{i18n:I18n {x:Static l:VexL.StatusState}}" Value="{Binding DocumentInfo.DocumentStateText}" />
                    <md:VexStatusBadge Label="{i18n:I18n {x:Static l:VexL.StatusEncoding}}" Value="{Binding DocumentInfo.CurrentEncodingText}" />
                    <TextBlock Classes="muted" Text="{Binding EditorDisplay.ZoomText}" VerticalAlignment="Center" />
                    <md:VexStatusBadge Label="{i18n:I18n {x:Static l:VexL.StatusLine}}" Value="{Binding Status.CaretLine}" />
                    <md:VexStatusBadge Label="{i18n:I18n {x:Static l:VexL.StatusColumn}}" Value="{Binding Status.CaretColumn}" />
                    <md:VexStatusBadge Label="{i18n:I18n {x:Static l:VexL.StatusWords}}" Value="{Binding DocumentInfo.Statistics.Words}" />
                    <md:VexStatusBadge Label="{i18n:I18n {x:Static l:VexL.StatusCharacters}}" Value="{Binding DocumentInfo.Statistics.Characters}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
