<Window
    x:Class="Vex.Modules.Shell.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Vex.Core.Messaging"
    xmlns:md="https://codewf.com"
    xmlns:models="using:Vex.Core.Models"
    xmlns:workspace="using:Vex.Modules.Workspace.Views"
    xmlns:vm="using:Vex.Modules.Shell.ViewModels"
    x:DataType="vm:MainWindowViewModel"
    Title="{Binding WindowTitle}"
    Width="1280"
    Height="820"
    MinWidth="980"
    MinHeight="640"
    Icon="/Assets/logo.ico"
    KeyDown="WindowKeyDown"
    WindowDecorations="None"
    WindowStartupLocation="CenterScreen">

    <Window.DataTemplates>
        <DataTemplate DataType="models:DocumentFile">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="3">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Classes="side-heading" Text="{Binding FolderName}" />
                    <TextBlock
                        Grid.Column="1"
                        Classes="muted"
                        FontSize="11"
                        Text="{Binding ModifiedText}" />
                </Grid>
                <TextBlock
                    Grid.Row="1"
                    FontWeight="SemiBold"
                    Text="{Binding Name}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="2"
                    Classes="muted"
                    MaxHeight="38"
                    Text="{Binding Preview}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="models:OutlineItem">
            <TextBlock
                Margin="{Binding IndentMargin}"
                Text="{Binding Title}"
                TextTrimming="CharacterEllipsis" />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid RowDefinitions="34,Auto,*,Auto" Background="#FFFDFDFD">
        <Border
            Grid.Row="0"
            Background="#FFF7F8FA"
            BorderBrush="#E4E7EC"
            BorderThickness="0 0 0 1"
            PointerPressed="TitleBarPointerPressed">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <StackPanel
                    Margin="10 0 10 0"
                    Orientation="Horizontal"
                    Spacing="7"
                    VerticalAlignment="Center">
                    <Image Width="16" Height="16" Source="/Assets/logo.png" />
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Vex"
                        VerticalAlignment="Center" />
                </StackPanel>

                <Menu
                    Grid.Column="1"
                    Classes="title-menu"
                    VerticalAlignment="Center">
                    <MenuItem Header="文件(F)">
                        <MenuItem Header="新建" Command="{Binding NewDocument}" />
                        <MenuItem Header="新建窗口" Command="{Binding NewWindow}" />
                        <Separator />
                        <MenuItem Header="打开..." Command="{Binding OpenAsync}" />
                        <MenuItem Header="打开文件夹..." Command="{Binding OpenFolderAsync}" />
                        <MenuItem Header="快速打开..." Command="{Binding QuickOpenAsync}" />
                        <MenuItem Header="打开最近文件" IsEnabled="{Binding HasRecentDocuments}">
                            <MenuItem Header="{Binding RecentDocument1Text}" Command="{Binding OpenRecentDocument1Async}" IsVisible="{Binding HasRecentDocument1}" />
                            <MenuItem Header="{Binding RecentDocument2Text}" Command="{Binding OpenRecentDocument2Async}" IsVisible="{Binding HasRecentDocument2}" />
                            <MenuItem Header="{Binding RecentDocument3Text}" Command="{Binding OpenRecentDocument3Async}" IsVisible="{Binding HasRecentDocument3}" />
                            <MenuItem Header="{Binding RecentDocument4Text}" Command="{Binding OpenRecentDocument4Async}" IsVisible="{Binding HasRecentDocument4}" />
                            <MenuItem Header="{Binding RecentDocument5Text}" Command="{Binding OpenRecentDocument5Async}" IsVisible="{Binding HasRecentDocument5}" />
                            <Separator />
                            <MenuItem Header="清空最近文件" Command="{Binding ClearRecentDocuments}" />
                        </MenuItem>
                        <MenuItem Header="选择编码重新打开">
                            <MenuItem Header="UTF-8" Command="{Binding ReopenWithEncodingAsync}" CommandParameter="utf-8" />
                            <MenuItem Header="UTF-8 BOM" Command="{Binding ReopenWithEncodingAsync}" CommandParameter="utf-8-bom" />
                            <MenuItem Header="GB18030" Command="{Binding ReopenWithEncodingAsync}" CommandParameter="GB18030" />
                            <MenuItem Header="Big5" Command="{Binding ReopenWithEncodingAsync}" CommandParameter="Big5" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="保存" Command="{Binding SaveAsync}" />
                        <MenuItem Header="另存为..." Command="{Binding SaveAsAsync}" />
                        <MenuItem Header="保存全部打开的文件..." Command="{Binding SaveAsync}" />
                        <Separator />
                        <MenuItem Header="属性..." Command="{Binding ShowProperties}" />
                        <MenuItem Header="打开文件位置..." Command="{Binding OpenFileLocationAsync}" IsEnabled="{Binding HasCurrentFile}" />
                        <MenuItem Header="删除..." Command="{Binding DeleteAsync}" IsEnabled="{Binding HasCurrentFile}" />
                        <Separator />
                        <MenuItem Header="导出">
                            <MenuItem Header="HTML" Command="{Binding Export}" CommandParameter="HTML" />
                            <MenuItem Header="PDF" Command="{Binding Export}" CommandParameter="PDF" />
                            <MenuItem Header="PNG" Command="{Binding Export}" CommandParameter="PNG" />
                        </MenuItem>
                        <MenuItem Header="打印..." Command="{Binding Print}" />
                        <Separator />
                        <MenuItem Header="关闭" Command="{Binding CloseDocument}" />
                    </MenuItem>

                    <MenuItem Header="编辑(E)">
                        <MenuItem Header="撤销" Command="{Binding Undo}" />
                        <MenuItem Header="重做" Command="{Binding Redo}" />
                        <Separator />
                        <MenuItem Header="剪切" Command="{Binding Cut}" />
                        <MenuItem Header="复制" Command="{Binding Copy}" />
                        <MenuItem Header="粘贴" Command="{Binding Paste}" />
                        <MenuItem Header="全选" Command="{Binding SelectAll}" />
                        <Separator />
                        <MenuItem Header="查找..." Command="{Binding ShowFindPanel}" InputGesture="Ctrl+F" />
                        <MenuItem Header="替换..." Command="{Binding ShowReplacePanel}" InputGesture="Ctrl+H" />
                    </MenuItem>

                    <MenuItem Header="段落(P)">
                        <MenuItem Header="段落" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Paragraph}" />
                        <MenuItem Header="标题 1" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Heading1}" />
                        <MenuItem Header="标题 2" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Heading2}" />
                        <MenuItem Header="标题 3" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Heading3}" />
                        <MenuItem Header="标题 4" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Heading4}" />
                        <MenuItem Header="标题 5" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Heading5}" />
                        <MenuItem Header="标题 6" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Heading6}" />
                        <Separator />
                        <MenuItem Header="表格" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Table}" />
                        <MenuItem Header="代码块" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.CodeFence}" />
                        <MenuItem Header="公式块" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.MathBlock}" />
                        <MenuItem Header="引用" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Quote}" />
                        <MenuItem Header="有序列表" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.OrderedList}" />
                        <MenuItem Header="无序列表" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.UnorderedList}" />
                        <MenuItem Header="任务列表" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.TaskList}" />
                        <MenuItem Header="水平分割线" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.HorizontalRule}" />
                    </MenuItem>

                    <MenuItem Header="格式(O)">
                        <MenuItem Header="加粗" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Bold}" />
                        <MenuItem Header="斜体" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Italic}" />
                        <MenuItem Header="代码" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.InlineCode}" />
                        <Separator />
                        <MenuItem Header="链接" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Link}" />
                        <MenuItem Header="图像" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.Image}" />
                        <MenuItem Header="清除样式" Command="{Binding InsertAction}" CommandParameter="{x:Static core:EditorActionKind.ClearFormatting}" />
                    </MenuItem>

                    <MenuItem Header="视图(V)">
                        <MenuItem Header="显示 / 隐藏侧边栏" Command="{Binding ToggleSidebar}" />
                        <MenuItem Header="大纲" Command="{Binding ShowOutline}" />
                        <MenuItem Header="文档列表" Command="{Binding ShowFiles}" />
                        <MenuItem Header="搜索" Command="{Binding ShowFindPanel}" InputGesture="Ctrl+F" />
                        <Separator />
                        <MenuItem Header="源代码模式" Command="{Binding ToggleSourceMode}" />
                        <MenuItem Header="显示状态栏" Command="{Binding ToggleStatusBar}" />
                        <MenuItem Header="字数统计窗口" Command="{Binding WordCount}" />
                        <Separator />
                        <MenuItem Header="切换全屏" Command="{Binding ToggleFullScreen}" />
                        <MenuItem Header="保持窗口在最前端" Command="{Binding ToggleAlwaysOnTop}" />
                        <Separator />
                        <MenuItem Header="实际大小" Command="{Binding ActualSize}" />
                        <MenuItem Header="放大" Command="{Binding ZoomIn}" />
                        <MenuItem Header="缩小" Command="{Binding ZoomOut}" />
                    </MenuItem>

                    <MenuItem Header="主题(T)">
                        <MenuItem Header="主题色">
                            <MenuItem Header="Light" Command="{Binding SelectThemeByKey}" CommandParameter="light" />
                            <MenuItem Header="Dark" Command="{Binding SelectThemeByKey}" CommandParameter="dark" />
                            <MenuItem Header="System" Command="{Binding SelectThemeByKey}" CommandParameter="system" />
                        </MenuItem>
                        <MenuItem Header="排版">
                            <MenuItem Header="简洁" Command="{Binding SelectTypographyByKey}" CommandParameter="Simple" />
                            <MenuItem Header="Basic" Command="{Binding SelectTypographyByKey}" CommandParameter="Basic" />
                            <MenuItem Header="橙心" Command="{Binding SelectTypographyByKey}" CommandParameter="OrangeHeart" />
                            <MenuItem Header="墨黑" Command="{Binding SelectTypographyByKey}" CommandParameter="InkBlack" />
                            <MenuItem Header="科技蓝" Command="{Binding SelectTypographyByKey}" CommandParameter="TechnologyBlue" />
                            <Separator />
                            <MenuItem Header="紧凑布局" Command="{Binding ToggleCompactLayout}" />
                        </MenuItem>
                    </MenuItem>

                    <MenuItem Header="国际化(L)">
                        <MenuItem Header="简体中文" Command="{Binding SelectLanguageByCulture}" CommandParameter="zh-CN" />
                        <MenuItem Header="繁體中文" Command="{Binding SelectLanguageByCulture}" CommandParameter="zh-Hant" />
                        <MenuItem Header="English" Command="{Binding SelectLanguageByCulture}" CommandParameter="en-US" />
                        <MenuItem Header="日本語" Command="{Binding SelectLanguageByCulture}" CommandParameter="ja-JP" />
                    </MenuItem>

                    <MenuItem Header="帮助(H)">
                        <MenuItem Header="更新日志" Command="{Binding OpenHelpTopic}" CommandParameter="changelog" />
                        <MenuItem Header="快速开始（引导）" Command="{Binding OpenHelpTopic}" CommandParameter="quick-start" />
                        <MenuItem Header="鸣谢" Command="{Binding OpenHelpTopic}" CommandParameter="thanks" />
                        <Separator />
                        <MenuItem Header="官方网站" Command="{Binding OpenHelpTopic}" CommandParameter="website" />
                        <MenuItem Header="反馈" Command="{Binding OpenHelpTopic}" CommandParameter="feedback" />
                        <MenuItem Header="关于" Command="{Binding OpenHelpTopic}" CommandParameter="about" />
                    </MenuItem>
                </Menu>

                <TextBlock
                    Grid.Column="2"
                    Classes="muted"
                    FontSize="12"
                    HorizontalAlignment="Center"
                    Text="{Binding CurrentDocumentTitle}"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center" />

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Classes="window-button" Click="MinimizeClicked" Content="_" />
                    <Button Classes="window-button" Click="MaximizeClicked" Content="[]" />
                    <Button Classes="window-button close" Click="CloseClicked" Content="X" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Background="#FFFFFFFF"
            BorderBrush="#E4E7EC"
            BorderThickness="0 0 0 1"
            IsVisible="{Binding IsFindPanelVisible}"
            Padding="10 8">
            <Grid ColumnDefinitions="Auto,220,Auto,220,Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
                <TextBlock
                    Classes="muted"
                    Text="Find"
                    VerticalAlignment="Center" />
                <TextBox
                    Grid.Column="1"
                    MinHeight="30"
                    Text="{Binding SearchText, Mode=TwoWay}"
                    PlaceholderText="Text" />
                <TextBlock
                    Grid.Column="2"
                    Classes="muted"
                    IsVisible="{Binding IsReplaceVisible}"
                    Text="Replace"
                    VerticalAlignment="Center" />
                <TextBox
                    Grid.Column="3"
                    IsVisible="{Binding IsReplaceVisible}"
                    MinHeight="30"
                    Text="{Binding ReplacementText, Mode=TwoWay}"
                    PlaceholderText="Text" />
                <Button
                    Grid.Column="4"
                    Command="{Binding FindNext}"
                    Content="Next"
                    MinWidth="72" />
                <Button
                    Grid.Column="5"
                    Command="{Binding ReplaceNext}"
                    Content="Replace"
                    IsVisible="{Binding IsReplaceVisible}"
                    MinWidth="82" />
                <Button
                    Grid.Column="6"
                    Command="{Binding ReplaceAll}"
                    Content="All"
                    IsVisible="{Binding IsReplaceVisible}"
                    MinWidth="64" />
                <Button
                    Grid.Column="7"
                    Command="{Binding CloseFindPanel}"
                    Content="X"
                    MinWidth="42" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarColumnWidth}" MinWidth="0" />
                <ColumnDefinition Width="{Binding SidebarSplitterWidth}" />
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition Width="{Binding PreviewSplitterWidth}" />
                <ColumnDefinition Width="{Binding PreviewColumnWidth}" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Classes="panel" IsVisible="{Binding IsSidebarVisible}">
                <TabControl SelectedIndex="{Binding SelectedSideTabIndex, Mode=TwoWay}">
                    <TabItem Header="文件">
                        <Grid>
                            <ListBox
                                Classes="side-list"
                                IsVisible="{Binding HasDocumentFiles}"
                                ItemsSource="{Binding DocumentFiles}"
                                SelectedItem="{Binding SelectedDocumentFile, Mode=TwoWay}" />
                            <Border
                                IsVisible="{Binding IsDocumentFilesEmpty}"
                                Padding="18"
                                VerticalAlignment="Top">
                                <TextBlock
                                    Classes="muted"
                                    Text="No files"
                                    TextAlignment="Center" />
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="大纲">
                        <Grid>
                            <ListBox
                                Classes="side-list"
                                IsVisible="{Binding HasOutlineItems}"
                                ItemsSource="{Binding OutlineItems}"
                                SelectedItem="{Binding SelectedOutlineItem, Mode=TwoWay}" />
                            <Border
                                IsVisible="{Binding IsOutlineEmpty}"
                                Padding="18"
                                VerticalAlignment="Top">
                                <TextBlock
                                    Classes="muted"
                                    Text="No headings"
                                    TextAlignment="Center" />
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsSidebarVisible}"
                ResizeDirection="Columns" />

            <workspace:MarkdownEditorView Grid.Column="2" />

            <GridSplitter
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsPreviewVisible}"
                ResizeDirection="Columns" />

            <Border
                Grid.Column="4"
                Background="White"
                IsVisible="{Binding IsPreviewVisible}"
                Padding="34 28 34 0">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <md:MarkdownViewer
                        Markdown="{Binding Markdown}"
                        TypographySize="{Binding CurrentTypographySize}"
                        TypographyTheme="{Binding CurrentTypographyTheme}" />
                </ScrollViewer>
            </Border>

            <Border
                Grid.ColumnSpan="5"
                Width="270"
                Margin="0 14 18 0"
                Padding="16"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#FFFFFFFF"
                BorderBrush="#D0D5DD"
                BorderThickness="1"
                CornerRadius="8"
                IsVisible="{Binding IsStatisticsPanelVisible}">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock
                            FontSize="15"
                            FontWeight="SemiBold"
                            Text="Statistics" />
                        <Button
                            Grid.Column="1"
                            Command="{Binding CloseStatisticsPanel}"
                            Content="X"
                            MinWidth="34"
                            Padding="0" />
                    </Grid>
                    <Grid
                        Grid.Row="1"
                        ColumnDefinitions="*,Auto"
                        RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                        RowSpacing="8">
                        <TextBlock Classes="muted" Text="Words" />
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding Statistics.Words}" />
                        <TextBlock Grid.Row="1" Classes="muted" Text="Characters" />
                        <TextBlock Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" Text="{Binding Statistics.Characters}" />
                        <TextBlock Grid.Row="2" Classes="muted" Text="Lines" />
                        <TextBlock Grid.Row="2" Grid.Column="1" FontWeight="SemiBold" Text="{Binding Statistics.Lines}" />
                        <TextBlock Grid.Row="3" Classes="muted" Text="Encoding" />
                        <TextBlock Grid.Row="3" Grid.Column="1" FontWeight="SemiBold" Text="{Binding CurrentEncodingText}" />
                        <TextBlock Grid.Row="4" Classes="muted" Text="State" />
                        <TextBlock Grid.Row="4" Grid.Column="1" FontWeight="SemiBold" Text="{Binding DocumentStateText}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border
            Grid.Row="3"
            Background="#FFF7F8FA"
            BorderBrush="#E4E7EC"
            BorderThickness="0 1 0 0"
            IsVisible="{Binding IsStatusBarVisible}"
            Padding="10 4">
            <Grid ColumnDefinitions="*,Auto" MinHeight="28">
                <TextBlock
                    Classes="muted"
                    Text="{Binding StatusText}"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center" />
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <md:VexStatusBadge Label="State" Value="{Binding DocumentStateText}" />
                    <md:VexStatusBadge Label="Encoding" Value="{Binding CurrentEncodingText}" />
                    <TextBlock Classes="muted" Text="{Binding ZoomText}" VerticalAlignment="Center" />
                    <md:VexStatusBadge Label="Line" Value="{Binding CaretLine}" />
                    <md:VexStatusBadge Label="Col" Value="{Binding CaretColumn}" />
                    <md:VexStatusBadge Label="Words" Value="{Binding Statistics.Words}" />
                    <md:VexStatusBadge Label="Chars" Value="{Binding Statistics.Characters}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
