<UserControl
    x:Class="Vex.Modules.Shell.Views.ShellAboutOverlayView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:i18n="https://codewf.com"
    xmlns:l="clr-namespace:Vex"
    xmlns:vm="using:Vex.Modules.Shell.ViewModels"
    x:DataType="vm:MainWindowViewModel">
    <Border
        Width="360"
        Padding="20"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="#FFFFFFFF"
        BorderBrush="#D0D5DD"
        BorderThickness="1"
        CornerRadius="8"
        IsVisible="{Binding Dialogs.IsAboutPanelVisible}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Image Width="32" Height="32" Source="/Assets/logo.png" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{i18n:I18n {x:Static l:VexL.AppName}}" />
                    <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:VexL.Slogan}}" />
                </StackPanel>
                <Button
                    Grid.Column="2"
                    Command="{Binding Dialogs.CloseAboutPanel}"
                    Content="X"
                    MinWidth="34"
                    Padding="0" />
            </Grid>
            <Grid
                Grid.Row="1"
                ColumnDefinitions="Auto,*"
                RowDefinitions="Auto,Auto,Auto,Auto"
                RowSpacing="8"
                ColumnSpacing="14">
                <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:VexL.AboutChineseNameLabel}}" />
                <TextBlock Grid.Column="1" Text="{i18n:I18n {x:Static l:VexL.ChineseName}}" />
                <TextBlock Grid.Row="1" Classes="muted" Text="{i18n:I18n {x:Static l:VexL.AboutAuthorLabel}}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{i18n:I18n {x:Static l:VexL.AboutAuthorName}}" />
                <TextBlock Grid.Row="2" Classes="muted" Text="{i18n:I18n {x:Static l:VexL.AboutWebsiteLabel}}" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="https://codewf.com" />
                <TextBlock Grid.Row="3" Classes="muted" Text="{i18n:I18n {x:Static l:VexL.AboutBrandLabel}}" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{i18n:I18n {x:Static l:VexL.AboutBrandName}}" />
            </Grid>
            <Separator Grid.Row="2" />
            <TextBlock
                Grid.Row="3"
                Classes="muted"
                Text="{i18n:I18n {x:Static l:VexL.AboutDescription}}"
                TextWrapping="Wrap" />
        </Grid>
    </Border>
</UserControl>
